{
  "name": "pi-rpc-http-server",
  "version": "0.1.0",
  "description": "HTTP front‑end for Pi RPC client",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "hf-push-sessions": "[ -d ./.pi/sessions/--code--/ ] && hf upload rgruchalski/combust-labs_pi-mono-http-proxy ./.pi/sessions/--code--/ --repo-type=dataset"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "prom-client": "^15.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/winston": "^2.4.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
